# PRD: F1 Login + language select (mobile 360)
direction: down

screen: {
  label: "Login — mobile 360"
  style.fill: "#ffffff"

  brand: {
    label: "Northwind Traders"
    style.fill: "#f4f4f3"
  }
  lang: {
    label: "Language: [ TH ] [ EN ] [ JA ]"
    style.fill: "#f4f4f3"
  }
  form: {
    label: "Sign in"
    direction: down
    email: "Email [____________]"
    password: "Password [____________]"
    error: "inline error slot"
    submit: {
      label: "[ Sign in ] (full width, 44px)"
      style.fill: "#f4f4f3"
    }
  }
}
