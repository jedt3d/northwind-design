# PRD: F1 Settings — language & profile (desktop 1280)
# GUI wireframe: one page frame, sidebar left, topbar on top, content zones stacked.
direction: down

classes: {
  frame: {style: {fill: "#ffffff"; stroke: "#999999"; stroke-width: 2; font-size: 16}}
  plain: {style: {fill: "#ffffff"; stroke: "#ffffff"}}
  bar: {style: {fill: "#f4f4f3"; stroke: "#999999"}}
  barlbl: {style: {fill: "#f4f4f3"; stroke: "#f4f4f3"}}
  slogo: {style: {fill: "#f4f4f3"; stroke: "#f4f4f3"; bold: true; font-size: 16}}
  nav: {style: {fill: "#f4f4f3"; stroke: "#f4f4f3"; font-size: 14}}
  navon: {style: {fill: "#1a1a1a"; stroke: "#1a1a1a"; font-color: "#ffffff"; font-size: 14}}
  h1: {style: {fill: "#ffffff"; stroke: "#ffffff"; bold: true; font-size: 20}}
  txt: {style: {fill: "#ffffff"; stroke: "#ffffff"; font-size: 13}}
  muted: {style: {fill: "#ffffff"; stroke: "#ffffff"; font-color: "#8a8a88"; font-size: 13}}
  zone: {style: {fill: "#ffffff"; stroke: "#999999"; font-size: 13}}
  field: {style: {fill: "#ffffff"; stroke: "#999999"; font-size: 13}}
  btn: {style: {fill: "#e5e6e8"; stroke: "#999999"; font-size: 13}}
  primary: {style: {fill: "#1a1a1a"; stroke: "#1a1a1a"; font-color: "#ffffff"; font-size: 13}}
  head: {style: {fill: "#e5e6e8"; stroke: "#999999"; bold: true; font-size: 13}}
  cell: {style: {fill: "#ffffff"; stroke: "#999999"; font-size: 13}}
}

page: {
  label: "Settings — desktop 1280"
  class: frame
  grid-columns: 2
  grid-gap: 0
  sidebar: {
    label: ""
    class: bar
    grid-columns: 1
    grid-gap: 6
    logo: {label: "Northwind Traders"; class: slogo; width: 180; height: 44}
    n0: {label: "Dashboard"; class: nav; width: 180; height: 34}
    n1: {label: "Orders"; class: nav; width: 180; height: 34}
    n2: {label: "Purchase orders"; class: nav; width: 180; height: 34}
    n3: {label: "Products"; class: nav; width: 180; height: 34}
    n4: {label: "Categories"; class: nav; width: 180; height: 34}
    n5: {label: "Inventory"; class: nav; width: 180; height: 34}
    n6: {label: "Companies"; class: nav; width: 180; height: 34}
    n7: {label: "Reports"; class: nav; width: 180; height: 34}
    n8: {label: "Admin"; class: nav; width: 180; height: 34}
    n9: {label: "Settings"; class: navon; width: 180; height: 34}
  }
  main: {
    label: ""
    class: plain
    grid-columns: 1
    grid-gap: 8
    topbar: {
      label: ""
      class: bar
      grid-columns: 3
      grid-gap: 8
      apptitle: {label: "Northwind Traders"; class: barlbl; width: 568; height: 36}
      lang: {label: "Language: EN ▾"; class: btn; width: 170; height: 36}
      user: {label: "Worajedt ▾"; class: btn; width: 170; height: 36}
    }
    h1: {label: "Settings"; class: h1; width: 940; height: 40}
    lang: {
      label: "Language"
      class: zone
      grid-columns: 1
      grid-gap: 6
      r: {
        label: ""
        class: plain
        grid-columns: 5
        grid-gap: 0
        sel: {label: "Language  [English ▾]  (ไทย / English / 日本語)"; class: field; width: 610; height: 38}
        gsp1: {label: ""; class: plain; width: 8; height: 38}
        s: {label: "Save"; class: primary; width: 160; height: 38}
        gsp2: {label: ""; class: plain; width: 8; height: 38}
        sp: {label: ""; class: plain; width: 142; height: 38}
      }
    }
    prof: {
      label: "Profile"
      class: zone
      grid-columns: 1
      grid-gap: 6
      r1: {
        label: ""
        class: plain
        grid-columns: 3
        grid-gap: 0
        f1: {label: "Username  [worajedt]  (read-only)"; class: field; width: 460; height: 38}
        gsp1: {label: ""; class: plain; width: 8; height: 38}
        f2: {label: "Role  [manager]  (read-only)"; class: field; width: 460; height: 38}
      }
      r2: {
        label: ""
        class: plain
        grid-columns: 3
        grid-gap: 0
        f1: {label: "First name  [Worajedt]"; class: field; width: 460; height: 38}
        gsp1: {label: ""; class: plain; width: 8; height: 38}
        f2: {label: "Last name  [S.]"; class: field; width: 460; height: 38}
      }
      r3: {
        label: ""
        class: plain
        grid-columns: 3
        grid-gap: 0
        f1: {label: "Job title  [Sales Manager]"; class: field; width: 460; height: 38}
        gsp1: {label: ""; class: plain; width: 8; height: 38}
        f2: {label: "Phone  [555-0188]"; class: field; width: 460; height: 38}
      }
      act: {
        label: ""
        class: plain
        grid-columns: 3
        grid-gap: 0
        s: {label: "Save profile"; class: primary; width: 180; height: 38}
        gsp1: {label: ""; class: plain; width: 8; height: 38}
        sp: {label: ""; class: plain; width: 740; height: 38}
      }
    }
    pass: {
      label: "Change password"
      class: zone
      grid-columns: 1
      grid-gap: 6
      r1: {
        label: ""
        class: plain
        grid-columns: 3
        grid-gap: 0
        f1: {label: "Current password  [••••••••]"; class: field; width: 460; height: 38}
        gsp1: {label: ""; class: plain; width: 8; height: 38}
        f2: {label: "New password  [••••••••]"; class: field; width: 460; height: 38}
      }
      r2: {
        label: ""
        class: plain
        grid-columns: 5
        grid-gap: 0
        f1: {label: "Confirm new password  [••••••••]"; class: field; width: 448; height: 38}
        gsp1: {label: ""; class: plain; width: 8; height: 38}
        s: {label: "Change password"; class: primary; width: 200; height: 38}
        gsp2: {label: ""; class: plain; width: 8; height: 38}
        sp: {label: ""; class: plain; width: 264; height: 38}
      }
    }
  }
}
