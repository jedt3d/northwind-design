# PRD: F3 Company detail (mobile 360)
# GUI wireframe: one narrow page frame, topbar with hamburger, zones stacked vertically.
direction: down

classes: {
  frame: {style: {fill: "#ffffff"; stroke: "#999999"; stroke-width: 2; font-size: 16}}
  plain: {style: {fill: "#ffffff"; stroke: "#ffffff"}}
  bar: {style: {fill: "#f4f4f3"; stroke: "#999999"}}
  barlbl: {style: {fill: "#f4f4f3"; stroke: "#f4f4f3"}}
  slogo: {style: {fill: "#f4f4f3"; stroke: "#f4f4f3"; bold: true; font-size: 16}}
  nav: {style: {fill: "#f4f4f3"; stroke: "#f4f4f3"; font-size: 14}}
  navon: {style: {fill: "#1a1a1a"; stroke: "#1a1a1a"; font-color: "#ffffff"; font-size: 14}}
  h1: {style: {fill: "#ffffff"; stroke: "#ffffff"; bold: true; font-size: 20}}
  txt: {style: {fill: "#ffffff"; stroke: "#ffffff"; font-size: 13}}
  muted: {style: {fill: "#ffffff"; stroke: "#ffffff"; font-color: "#8a8a88"; font-size: 13}}
  zone: {style: {fill: "#ffffff"; stroke: "#999999"; font-size: 13}}
  field: {style: {fill: "#ffffff"; stroke: "#999999"; font-size: 13}}
  btn: {style: {fill: "#e5e6e8"; stroke: "#999999"; font-size: 13}}
  primary: {style: {fill: "#1a1a1a"; stroke: "#1a1a1a"; font-color: "#ffffff"; font-size: 13}}
  head: {style: {fill: "#e5e6e8"; stroke: "#999999"; bold: true; font-size: 13}}
  cell: {style: {fill: "#ffffff"; stroke: "#999999"; font-size: 13}}
}

page: {
  label: "Company — detail — mobile 360"
  class: frame
  grid-columns: 1
  grid-gap: 8
  topbar: {
    label: ""
    class: bar
    grid-columns: 3
    grid-gap: 6
    menu: {label: "☰"; class: btn; width: 44; height: 36}
    apptitle: {label: "Northwind Traders"; class: barlbl; width: 190; height: 36}
    user: {label: "WS ▾"; class: btn; width: 64; height: 36}
  }
  back: {label: "‹ Companies"; class: muted; width: 320; height: 26}
  h1: {label: "Adatum Corporation"; class: h1; width: 320; height: 36}
  f1: {label: "Company name  [Adatum Corporation]"; class: field; width: 320; height: 38}
  f2: {label: "Types  [customer ▾]"; class: field; width: 320; height: 38}
  f3: {label: "Contact  [Elizabeth Andersen]"; class: field; width: 320; height: 38}
  f4: {label: "Email  [info@adatum.com]"; class: field; width: 320; height: 38}
  f5: {label: "Phone  [555-0100]"; class: field; width: 320; height: 38}
  f6: {label: "Address · City · State"; class: field; width: 320; height: 38}
  f7: {label: "Postal · Country · Tax ID"; class: field; width: 320; height: 38}
  notes: {label: "Notes  [__________________]"; class: field; width: 320; height: 38}
  save: {
    label: ""
    class: plain
    grid-columns: 2
    grid-gap: 8
    s: {label: "Save"; class: primary; width: 150; height: 40}
    c: {label: "Cancel"; class: btn; width: 150; height: 40}
  }
  rel: {label: "Related\nSO-2026-0042 (New) · SO-2026-0038"; class: zone; width: 320; height: 58}
  del: {label: "Delete company"; class: btn; width: 320; height: 36}
}
