# PRD: F7 Inventory on-hand (desktop 1280)
direction: down

screen: {
  label: "Inventory on-hand — desktop 1280"
  style.fill: "#ffffff"

  topbar: {
    label: "Northwind | lang | user"
    style.fill: "#f4f4f3"
  }
  main: {
    direction: right
    sidebar: {
      label: "sidebar: Inventory (active)"
      style.fill: "#f4f4f3"
    }
    content: {
      direction: down
      header: {
        grid-columns: 2
        title: "H1 Stock on hand"
        action: {
          label: "[ New adjustment ]"
          style.fill: "#f4f4f3"
        }
      }
      toolbar: {
        grid-columns: 2
        search: "Search product..."
        filter: "[ ] Below reorder level only"
      }
      table: {
        direction: down
        head: {
          label: "Product ^ | On hand | Allocated | Available | On order | Reorder lvl"
          style.fill: "#f4f4f3"
        }
        row1: "Chai Tea | 22 | 10 | 12 (LOW) | 100 | 50"
        row2: "Syrup | 80 | 0 | 80 | 0 | 25"
        row3: "Green Tea | 5 | 5 | 0 (LOW) | 60 | 20"
      }
      pager: "1-20 of 77   < 1 2 3 4 >"
    }
  }
}
