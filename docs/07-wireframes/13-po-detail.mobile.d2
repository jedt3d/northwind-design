# PRD: F6 PO detail — approve / receive (mobile 360)
# GUI wireframe: one narrow page frame, topbar with hamburger, zones stacked vertically.
direction: down

classes: {
  frame: {style: {fill: "#ffffff"; stroke: "#999999"; stroke-width: 2; font-size: 16}}
  plain: {style: {fill: "#ffffff"; stroke: "#ffffff"}}
  bar: {style: {fill: "#f4f4f3"; stroke: "#999999"}}
  barlbl: {style: {fill: "#f4f4f3"; stroke: "#f4f4f3"}}
  slogo: {style: {fill: "#f4f4f3"; stroke: "#f4f4f3"; bold: true; font-size: 16}}
  nav: {style: {fill: "#f4f4f3"; stroke: "#f4f4f3"; font-size: 14}}
  navon: {style: {fill: "#1a1a1a"; stroke: "#1a1a1a"; font-color: "#ffffff"; font-size: 14}}
  h1: {style: {fill: "#ffffff"; stroke: "#ffffff"; bold: true; font-size: 20}}
  txt: {style: {fill: "#ffffff"; stroke: "#ffffff"; font-size: 13}}
  muted: {style: {fill: "#ffffff"; stroke: "#ffffff"; font-color: "#8a8a88"; font-size: 13}}
  zone: {style: {fill: "#ffffff"; stroke: "#999999"; font-size: 13}}
  field: {style: {fill: "#ffffff"; stroke: "#999999"; font-size: 13}}
  btn: {style: {fill: "#e5e6e8"; stroke: "#999999"; font-size: 13}}
  primary: {style: {fill: "#1a1a1a"; stroke: "#1a1a1a"; font-color: "#ffffff"; font-size: 13}}
  head: {style: {fill: "#e5e6e8"; stroke: "#999999"; bold: true; font-size: 13}}
  cell: {style: {fill: "#ffffff"; stroke: "#999999"; font-size: 13}}
}

page: {
  label: "Purchase order — detail — mobile 360"
  class: frame
  grid-columns: 1
  grid-gap: 8
  topbar: {
    label: ""
    class: bar
    grid-columns: 3
    grid-gap: 6
    menu: {label: "☰"; class: btn; width: 44; height: 36}
    apptitle: {label: "Northwind Traders"; class: barlbl; width: 190; height: 36}
    user: {label: "WS ▾"; class: btn; width: 64; height: 36}
  }
  back: {label: "‹ Purchase orders"; class: muted; width: 320; height: 26}
  h1: {label: "PO-2026-0108 · Submitted"; class: h1; width: 320; height: 36}
  info: {label: "Exotic Liquids · by N. Freehafer\nSubmitted 07-07 · Expected 07-15"; class: zone; width: 320; height: 58}
  act1: {
    label: ""
    class: plain
    grid-columns: 2
    grid-gap: 8
    appr: {label: "Approve"; class: primary; width: 155; height: 40}
    recv: {label: "Receive…"; class: btn; width: 155; height: 40}
  }
  cancel: {label: "Cancel PO"; class: btn; width: 320; height: 36}
  lines: {
    label: "Lines"
    class: zone
    grid-columns: 1
    grid-gap: 6
    l1: {label: "Chai × 40 @ 13.50\n540.00 · received — · posted ☐"; class: zone; width: 290; height: 58}
    l2: {label: "Aniseed Syrup × 30 @ 7.50\n225.00 · received — · posted ☐"; class: zone; width: 290; height: 58}
  }
  recvbox: {
    label: "Receive (warehouse)"
    class: zone
    grid-columns: 1
    grid-gap: 6
    date: {label: "Date received [2026-07-15]"; class: field; width: 290; height: 36}
    post: {label: "Post to inventory"; class: primary; width: 290; height: 36}
  }
  totals: {label: "Subtotal 765.00 · Shipping 0.00\nTotal 765.00"; class: zone; width: 320; height: 58}
}
