# PRD: F5 Order detail + status actions (mobile 360)
# GUI wireframe: one narrow page frame, topbar with hamburger, zones stacked vertically.
direction: down

classes: {
  frame: {style: {fill: "#ffffff"; stroke: "#999999"; stroke-width: 2; font-size: 16}}
  plain: {style: {fill: "#ffffff"; stroke: "#ffffff"}}
  bar: {style: {fill: "#f4f4f3"; stroke: "#999999"}}
  barlbl: {style: {fill: "#f4f4f3"; stroke: "#f4f4f3"}}
  slogo: {style: {fill: "#f4f4f3"; stroke: "#f4f4f3"; bold: true; font-size: 16}}
  nav: {style: {fill: "#f4f4f3"; stroke: "#f4f4f3"; font-size: 14}}
  navon: {style: {fill: "#1a1a1a"; stroke: "#1a1a1a"; font-color: "#ffffff"; font-size: 14}}
  h1: {style: {fill: "#ffffff"; stroke: "#ffffff"; bold: true; font-size: 20}}
  txt: {style: {fill: "#ffffff"; stroke: "#ffffff"; font-size: 13}}
  muted: {style: {fill: "#ffffff"; stroke: "#ffffff"; font-color: "#8a8a88"; font-size: 13}}
  zone: {style: {fill: "#ffffff"; stroke: "#999999"; font-size: 13}}
  field: {style: {fill: "#ffffff"; stroke: "#999999"; font-size: 13}}
  btn: {style: {fill: "#e5e6e8"; stroke: "#999999"; font-size: 13}}
  primary: {style: {fill: "#1a1a1a"; stroke: "#1a1a1a"; font-color: "#ffffff"; font-size: 13}}
  head: {style: {fill: "#e5e6e8"; stroke: "#999999"; bold: true; font-size: 13}}
  cell: {style: {fill: "#ffffff"; stroke: "#999999"; font-size: 13}}
}

page: {
  label: "Order — detail — mobile 360"
  class: frame
  grid-columns: 1
  grid-gap: 8
  topbar: {
    label: ""
    class: bar
    grid-columns: 3
    grid-gap: 6
    menu: {label: "☰"; class: btn; width: 44; height: 36}
    apptitle: {label: "Northwind Traders"; class: barlbl; width: 204; height: 36}
    user: {label: "WS ▾"; class: btn; width: 64; height: 36}
  }
  back: {label: "‹ Orders"; class: muted; width: 336; height: 26}
  h1: {label: "SO-2026-0042 · New"; class: h1; width: 336; height: 36}
  info: {label: "Adatum Corporation · Worajedt S.\nOrdered 2026-07-08 · Invoice — · Ship —"; class: zone; width: 336; height: 58}
  act1: {
    label: ""
    class: plain
    grid-columns: 3
    grid-gap: 0
    inv: {label: "Invoice"; class: primary; width: 164; height: 40}
    gsp1: {label: ""; class: plain; width: 8; height: 40}
    ship: {label: "Ship…"; class: btn; width: 164; height: 40}
  }
  act2: {
    label: ""
    class: plain
    grid-columns: 3
    grid-gap: 0
    close: {label: "Close"; class: btn; width: 164; height: 36}
    gsp1: {label: ""; class: plain; width: 8; height: 36}
    cancel: {label: "Cancel order"; class: btn; width: 164; height: 36}
  }
  lines: {
    label: "Lines"
    class: zone
    grid-columns: 1
    grid-gap: 6
    l1: {label: "Chai × 10 @ 18.00\nAllocated · 180.00 · Edit · Del"; class: zone; width: 324; height: 58}
    l2: {label: "Aniseed Syrup × 4 @ 10.00\nOn order · 38.00 · Edit · Del"; class: zone; width: 324; height: 58}
    l3: {label: "Ikura × 2 @ 31.00\nNo stock ⚠ Create PO? · 62.00"; class: zone; width: 324; height: 58}
  }
  addline: {
    label: "Add line"
    class: zone
    grid-columns: 1
    grid-gap: 6
    prod: {label: "Product  [Chang ▾]"; class: field; width: 324; height: 36}
    qa: {
      label: ""
      class: plain
      grid-columns: 3
      grid-gap: 0
      qty: {label: "Qty [1]"; class: field; width: 158; height: 36}
      gsp1: {label: ""; class: plain; width: 8; height: 36}
      add: {label: "Add"; class: btn; width: 158; height: 36}
    }
  }
  totals: {label: "Subtotal 280.00 · Shipping 20.00\nTaxes 0.00 · Total 300.00"; class: zone; width: 336; height: 58}
  del: {label: "Delete order"; class: btn; width: 336; height: 36}
}
